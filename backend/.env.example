# OpenWorld Environment Configuration
# Bu dosyayi .env olarak kopyalayin ve kendi degerlerinizi girin

# ============================================
# YAPAY ZEKA MODEL AYARLARI
# ============================================

# LLM Backend: ollama veya llama_cpp
LLM_BACKEND=ollama

# Ollama model adi (Ollama kullaniyorsaniz)
OLLAMA_MODEL=qwen3.5:9b-q4_K_M

# GGUF model yolu (llama_cpp kullaniyorsaniz)
LLAMA_MODEL_PATH=../models/Qwen3.5-9B-Q4_K_M.gguf

# ============================================
# TELEGRAM BOT AYARLARI (Istege Bagli)
# ============================================

# Telegram Bot Token (@BotFather'dan alin)
TELEGRAM_BOT_TOKEN=

# Sadece bu kullanici erisebilir (@userinfobot'dan ogrenin)
TELEGRAM_ALLOWED_USER_ID=

# ============================================
# GMAIL ENTegrasyonu (Istege Bagli)
# ============================================

# Google Cloud Console'dan alinan Client ID
# Format: xxx.apps.googleusercontent.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# OAuth sonrasi otomatik doldurulur (veya manuel girin)
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=

# ============================================
# OUTLOOK ENTegrasyonu (Istege Bagli)
# ============================================

# Azure Portal > App registrations > Application (client) ID
OUTLOOK_CLIENT_ID=

# Tenant ID: common, organizations, consumers veya tenant GUID
OUTLOOK_TENANT_ID=common

# OAuth sonrasi otomatik doldurulur
OUTLOOK_ACCESS_TOKEN=
OUTLOOK_REFRESH_TOKEN=

# ============================================
# GUVENLIK AYARLARI
# ============================================

# Domain kisitlamasi (bos = tumune izin)
# Ornek: "github.com,stackoverflow.com"
WEB_ALLOWED_DOMAINS=

# Yerel ag adreslerini engelle (localhost, 192.168.x.x vb.)
WEB_BLOCK_PRIVATE_HOSTS=true

# Shell komut calistirmaya izin ver (true/false)
ENABLE_SHELL_TOOL=false

# ============================================
# KULLANICI PROFILI
# ============================================

OWNER_NAME=Kullanici
OWNER_PROFILE=Teknoloji, yazilim, otomasyon
